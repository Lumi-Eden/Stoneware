{
  "name": "stoneware",
  "version": "0.4.2-beta",
  "description": "",
  "main": "script/main.js",
  "build": {
    "appId": "com.stoneware.app",
    "win": {
      "icon": "tombstone.ico",
      "target": {
        "target": "nsis",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Lumi-Eden",
        "repo": "Stoneware"
      }
    ],
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin",
      "*.html",
      "package.json"
    ]
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:x64": "electron-builder --win --x64",
    "build:win:arm": "electron-builder --win --arm64"
  },
  "author": "Radek Štekl",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-reloader": "^1.2.3"
  }
}
